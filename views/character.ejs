<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= character.name %> — Character Profile
  </title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link rel="stylesheet" href="/styles/styles.css">
</head>

<body>

  <!-- Save Markdown Button -->
  <a href="/character/<%= character.id %>/markdown"
    class="fixed top-4 left-4 z-50 px-4 py-2 bg-indigo-600 text-white rounded-lg shadow-lg hover:bg-indigo-700 transition flex items-center gap-2 no-print"
    title="Save Markdown">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>
    <span>Save Markdown</span>
  </a>

  <form id="character-form" method="POST" action="/character/<%= character.id %>?_method=PUT">

    <!-- Top Controls Bar -->
    <div class="max-w-[1200px] mx-auto mb-6 flex justify-between items-center no-print">
      <a href="/hall" class="rpg-btn rpg-btn-secondary flex items-center gap-2">
        &larr; Back to Hall
      </a>
      <div class="flex gap-2">
        <button type="button" id="edit-toggle" class="rpg-btn rpg-btn-primary">
          Edit Profile
        </button>
        <button type="button" id="cancel-edit" class="rpg-btn rpg-btn-secondary hidden">
          Cancel
        </button>
        <button type="submit" id="save-btn" class="rpg-btn rpg-btn-success hidden">
          Save Changes
        </button>
        <button type="button" id="delete-btn" onclick="confirmDelete()" class="rpg-btn rpg-btn-danger">
          Delete Character
        </button>
      </div>
    </div>

    <div class="rpg-container">

      <!-- LEFT COLUMN: Character Card (Sidebar) -->
      <aside class="space-y-6">

        <!-- Portrait & Core Info -->
        <div class="rpg-panel">
          <div class="rpg-portrait-container" id="portrait-container">
            <img src="<%= character.portrait || '/images/aasimar_artificer.png' %>" alt="Character Portrait"
              class="rpg-portrait" id="portrait-img">
            <div class="rpg-portrait-overlay">
              <input name="name"
                class="rpg-title text-2xl font-bold bg-transparent border-none focus:ring-0 editable-input" type="text"
                value="<%= character.name %>" readonly />
              <div class="text-sm text-gray-300 rpg-header-font">
                <%= classStr %>
              </div>
            </div>
          </div>

          <div class="rpg-panel-content space-y-4">
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div>
                <span class="label-small block">Race</span>
                <span class="font-semibold text-gray-200">
                  <%= raceDisplay %>
                </span>
              </div>
              <div>
                <span class="label-small block">Background</span>
                <span class="font-semibold text-gray-200">
                  <%= bgStr %>
                </span>
              </div>
              <div>
                <span class="label-small block">Alignment</span>
                <select name="alignment"
                  class="w-full bg-transparent border-none p-0 text-gray-200 font-semibold editable-input" disabled>
                  <option value="">Select...</option>
                  <% const alignments=["Lawful Good", "Neutral Good" , "Chaotic Good" , "Lawful Neutral"
                    , "True Neutral" , "Chaotic Neutral" , "Lawful Evil" , "Neutral Evil" , "Chaotic Evil" ]; %>
                    <% alignments.forEach(function(a) { %>
                      <option value="<%= a %>" <%=character.alignment===a ? 'selected' : '' %>><%= a %>
                      </option>
                      <% }); %>
                </select>
              </div>
              <div>
                <span class="label-small block">Experience</span>
                <input name="experience"
                  class="w-full bg-transparent border-none p-0 text-gray-200 font-semibold editable-input" type="number"
                  value="<%= character.experience %>" readonly min="0" />
              </div>
            </div>
          </div>
        </div>

        <!-- Health Pool -->
        <div class="rpg-panel">
          <div class="rpg-panel-header">
            <span class="rpg-header-font font-bold text-sm">Vitality & Health</span>
            <div class="text-xs text-gray-400">
              Max HP: <input name="maxHitPoints"
                class="w-12 text-center bg-transparent border-none p-0 font-bold editable-input" type="number"
                value="<%= character.maxHitPoints %>" readonly min="1" />
            </div>
          </div>
          <div class="rpg-panel-content space-y-3">
            <div class="rpg-hp-bar-container">
              <% const hpPercent=character.maxHitPoints> 0 ? Math.min(100, Math.max(0, (character.currentHitPoints /
                character.maxHitPoints) * 100)) : 0; %>
                <div class="rpg-hp-bar" style="width: <%= hpPercent %>%;"></div>
                <span class="rpg-hp-text">
                  <input name="currentHitPoints"
                    class="w-10 text-center bg-transparent border-none p-0 font-bold text-white text-xs" type="number"
                    value="<%= character.currentHitPoints %>" readonly /> / <%= character.maxHitPoints %> HP
                </span>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div class="rpg-combat-stat-box">
                <span class="label-small">Temp HP</span>
                <input name="tempHitPoints"
                  class="w-full text-center bg-transparent border-none p-0 font-bold text-sm text-blue-300 editable-input"
                  type="number" value="<%= character.tempHitPoints || 0 %>" readonly />
              </div>
              <div class="rpg-combat-stat-box">
                <span class="label-small">Hit Dice</span>
                <span class="font-bold text-sm text-gray-200">
                  <%= hitDieStr || '—' %>
                </span>
              </div>
            </div>
          </div>
        </div>

        <!-- Combat Stats -->
        <div class="rpg-panel">
          <div class="rpg-panel-header">
            <span class="rpg-header-font font-bold text-sm">Combat Attributes</span>
          </div>
          <div class="rpg-panel-content space-y-4">
            <div class="rpg-combat-stats">
              <div class="rpg-combat-stat-box">
                <span class="label-small">Armor Class</span>
                <input name="armorClass"
                  class="w-12 text-center bg-transparent border-none p-0 font-bold text-xl text-yellow-500 editable-input"
                  type="number" value="<%= character.armorClass?.baseValue || 10 %>" readonly min="0" />
              </div>
              <div class="rpg-combat-stat-box">
                <span class="label-small">Initiative</span>
                <input name="initiative"
                  class="w-12 text-center bg-transparent border-none p-0 font-bold text-xl text-yellow-500 editable-input"
                  type="number" value="<%= character.initiative?.baseValue || 0 %>" readonly />
              </div>
              <div class="rpg-combat-stat-box">
                <span class="label-small">Speed</span>
                <input name="speed"
                  class="w-12 text-center bg-transparent border-none p-0 font-bold text-xl text-yellow-500 editable-input"
                  type="number" value="<%= character.speed?.baseValue || 30 %>" readonly min="0" />
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div class="rpg-combat-stat-box">
                <span class="label-small">Proficiency</span>
                <input name="proficiencyBonus"
                  class="w-12 text-center bg-transparent border-none p-0 font-bold text-sm text-gray-200 editable-input"
                  type="text" value="<%= profBonusStr %>" readonly />
              </div>
              <div class="rpg-combat-stat-box">
                <span class="label-small">Passive Perc.</span>
                <input name="passivePerception"
                  class="w-12 text-center bg-transparent border-none p-0 font-bold text-sm text-gray-200 editable-input"
                  type="number" value="<%= character.passivePerception || 10 %>" readonly min="0" />
              </div>
            </div>

            <!-- Death Saves -->
            <div class="border-t border-gray-800 pt-3">
              <span class="label-small block text-center mb-2">Death Saves</span>
              <div class="flex justify-between text-xs">
                <div class="flex items-center gap-1">
                  <span class="text-gray-400">Successes:</span>
                  <div class="bubble <%= character.deathSaveSuccess1 ? 'filled' : '' %>"
                    onclick="toggleDeathSave(this, 'success1')"></div>
                  <div class="bubble <%= character.deathSaveSuccess2 ? 'filled' : '' %>"
                    onclick="toggleDeathSave(this, 'success2')"></div>
                  <div class="bubble <%= character.deathSaveSuccess3 ? 'filled' : '' %>"
                    onclick="toggleDeathSave(this, 'success3')"></div>
                </div>
                <div class="flex items-center gap-1">
                  <span class="text-gray-400">Failures:</span>
                  <div class="bubble <%= character.deathSaveFail1 ? 'filled' : '' %>"
                    onclick="toggleDeathSave(this, 'fail1')"></div>
                  <div class="bubble <%= character.deathSaveFail2 ? 'filled' : '' %>"
                    onclick="toggleDeathSave(this, 'fail2')"></div>
                  <div class="bubble <%= character.deathSaveFail3 ? 'filled' : '' %>"
                    onclick="toggleDeathSave(this, 'fail3')"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Hidden Checkboxes for JS State -->
        <input type="checkbox" name="inspiration" id="inspiration" value="1" <%=character.inspiration ? 'checked' : ''
          %> class="hidden"/>
        <input type="checkbox" name="deathSaveSuccess1" class="hidden" <%=character.deathSaveSuccess1 ? 'checked' : ''
          %>/>
        <input type="checkbox" name="deathSaveSuccess2" class="hidden" <%=character.deathSaveSuccess2 ? 'checked' : ''
          %>/>
        <input type="checkbox" name="deathSaveSuccess3" class="hidden" <%=character.deathSaveSuccess3 ? 'checked' : ''
          %>/>
        <input type="checkbox" name="deathSaveFail1" class="hidden" <%=character.deathSaveFail1 ? 'checked' : '' %>/>
        <input type="checkbox" name="deathSaveFail2" class="hidden" <%=character.deathSaveFail2 ? 'checked' : '' %>/>
        <input type="checkbox" name="deathSaveFail3" class="hidden" <%=character.deathSaveFail3 ? 'checked' : '' %>/>
        <input name="player" type="hidden" value="<%= character.player || '' %>" />
        <input type="hidden" name="portrait" id="portrait-data" value="<%= character.portrait || '' %>" />
        <input type="file" id="portrait-upload" accept="image/*" class="hidden" />

      </aside>

      <!-- RIGHT COLUMN: Main Content & Tabs -->
      <main class="space-y-6">

        <!-- Tabs Navigation -->
        <nav class="rpg-tabs no-print">
          <button type="button" class="rpg-tab-btn active" onclick="switchTab('tab-attributes')">Attributes &
            Skills</button>
          <button type="button" class="rpg-tab-btn" onclick="switchTab('tab-inventory')">Inventory & Equipment</button>
          <button type="button" class="rpg-tab-btn" onclick="switchTab('tab-features')">Features & Biography</button>
          <% if (spellData) { %>
            <button type="button" class="rpg-tab-btn" onclick="switchTab('tab-spellbook')">Spellbook</button>
            <% } %>
        </nav>

        <!-- TAB 1: Attributes & Skills -->
        <section id="tab-attributes" class="rpg-tab-content active space-y-6">

          <!-- Ability Scores -->
          <div class="rpg-panel">
            <div class="rpg-panel-header">
              <span class="rpg-header-font font-bold text-sm">Ability Scores</span>
              <div class="flex items-center gap-2">
                <div id="inspiration-bubble" class="bubble <%= character.inspiration ? 'filled' : '' %>"
                  onclick="toggleInspiration()"></div>
                <span class="label-small">Inspiration</span>
              </div>
            </div>
            <div class="rpg-panel-content">
              <div class="rpg-abilities-grid">
                <% abilityData.forEach(function(a) { %>
                  <div class="rpg-ability-card">
                    <span class="label-small mb-1">
                      <%= a.name %>
                    </span>
                    <input name="abilityScores[<%= a.name %>]"
                      class="w-16 text-center rpg-ability-score bg-transparent border-none p-0 editable-input"
                      type="number" value="<%= a.score %>" readonly min="1" max="30" />
                    <div class="rpg-ability-mod">
                      <%= a.modStr %>
                    </div>
                  </div>
                  <% }); %>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Saving Throws -->
            <div class="rpg-panel">
              <div class="rpg-panel-header">
                <span class="rpg-header-font font-bold text-sm">Saving Throws</span>
              </div>
              <div class="rpg-panel-content space-y-1">
                <% savingThrows.forEach(function(st) { %>
                  <div class="skill-row">
                    <div class="bubble <%= st.proficient ? 'filled' : '' %>" data-save="<%= st.name %>"
                      onclick="toggleSaveBubble(this)"></div>
                    <input type="checkbox" name="savingThrows[<%= st.name %>]" class="hidden" <%=st.proficient
                      ? 'checked' : '' %>/>
                    <span class="w-8 font-bold text-yellow-500 text-right mr-3">
                      <%= st.modStr %>
                    </span>
                    <span class="text-gray-200">
                      <%= st.label %>
                    </span>
                  </div>
                  <% }); %>
              </div>
            </div>

            <!-- Skills -->
            <div class="rpg-panel">
              <div class="rpg-panel-header">
                <span class="rpg-header-font font-bold text-sm">Skills</span>
              </div>
              <div class="rpg-panel-content space-y-1 max-h-[400px] overflow-y-auto">
                <% skills.forEach(function(sk) { %>
                  <div class="skill-row">
                    <div class="bubble <%= sk.proficient ? 'filled' : '' %>" data-skill="<%= sk.name %>"
                      onclick="toggleSkillBubble(this)"></div>
                    <input type="checkbox" name="skills[<%= sk.name %>]" value="1" class="hidden" <%=sk.proficient
                      ? 'checked' : '' %>/>
                    <input type="checkbox" name="skillExpertise[<%= sk.name %>]" value="1" class="hidden"
                      <%=sk.expertise ? 'checked' : '' %>/>
                    <span class="w-8 font-bold text-yellow-500 text-right mr-3">
                      <%= sk.modStr %>
                    </span>
                    <span class="text-gray-200 flex-grow">
                      <%= sk.label %>
                    </span>
                    <span class="text-gray-500 text-xs">(<%= sk.ability %>)</span>
                  </div>
                  <% }); %>
              </div>
            </div>
          </div>

        </section>

        <!-- TAB 2: Inventory & Equipment -->
        <section id="tab-inventory" class="rpg-tab-content space-y-6">

          <!-- Wealth & Currency -->
          <div class="rpg-panel">
            <div class="rpg-panel-header">
              <span class="rpg-header-font font-bold text-sm">Treasury & Coins</span>
            </div>
            <div class="rpg-panel-content">
              <div class="rpg-currency-grid">
                <% const currencies=['cp', 'sp' , 'ep' , 'gp' , 'pp' ]; %>
                  <% currencies.forEach(function(c) { %>
                    <div class="rpg-currency-box <%= c %>">
                      <span class="rpg-currency-label">
                        <%= c.toUpperCase() %>
                      </span>
                      <input name="currency[<%= c %>]"
                        class="w-full text-center bg-transparent border-none p-0 text-sm font-bold text-gray-200 editable-input"
                        type="number" value="<%= character.currency?.[c] || 0 %>" readonly min="0" />
                    </div>
                    <% }); %>
              </div>
            </div>
          </div>

          <!-- Weapons & Attacks -->
          <div class="rpg-panel">
            <div class="rpg-panel-header">
              <span class="rpg-header-font font-bold text-sm">Weapons & Attacks</span>
            </div>
            <div class="rpg-panel-content">
              <table class="w-full text-left text-sm">
                <thead>
                  <tr>
                    <th class="pb-2">Weapon Name</th>
                    <th class="pb-2 text-center">Atk Bonus</th>
                    <th class="pb-2">Damage / Type</th>
                  </tr>
                </thead>
                <tbody>
                  <% weapons.forEach(function(w) { %>
                    <tr>
                      <td class="py-2 text-gray-200 font-semibold">
                        <span class="rpg-tooltip-trigger" data-type="item" data-name="<%= w.name %>">
                          <%= w.name %>
                        </span>
                      </td>
                      <td class="py-2 text-center text-yellow-500 font-bold">
                        <%= w.atkBonusStr %>
                      </td>
                      <td class="py-2 text-gray-300">
                        <%= w.damage %>
                      </td>
                    </tr>
                    <% }); %>
                      <% if (weapons.length===0) { %>
                        <tr>
                          <td colspan="3" class="py-4 text-center text-gray-500 italic">No weapons equipped.</td>
                        </tr>
                        <% } %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Equipment List -->
          <div class="rpg-panel">
            <div class="rpg-panel-header">
              <span class="rpg-header-font font-bold text-sm">Equipment & Gear</span>
              <div class="equipment-add" id="add-equipment-btn" onclick="addEquipment()">+ Add Item</div>
            </div>
            <div class="rpg-panel-content">
              <div id="equipment-list" class="space-y-2 max-h-[300px] overflow-y-auto">
                <% equipment.forEach(function(e, idx) { %>
                  <div class="equipment-item flex items-center justify-between gap-4" data-index="<%= idx %>">
                    <div class="flex items-center gap-2 flex-grow">
                      <span class="equipment-delete" onclick="removeEquipment('<%= idx %>')">&times;</span>
                      <input type="text" name="equipment[<%= idx %>][name]" value="<%= e.name %>" readonly
                        class="w-full bg-transparent border-none p-0 text-sm font-semibold text-gray-200 editable-input"
                        placeholder="Item name" />
                    </div>
                    <div class="flex items-center gap-1">
                      <span class="text-xs text-gray-500">Qty:</span>
                      <input type="number" name="equipment[<%= idx %>][quantity]" value="<%= e.quantity %>" readonly
                        min="1"
                        class="w-16 text-center bg-transparent border-none p-0 text-sm font-bold text-gray-200 editable-input"
                        placeholder="Qty" />
                    </div>
                  </div>
                  <% }); %>
              </div>
            </div>
          </div>

        </section>

        <!-- TAB 3: Biography & Features -->
        <section id="tab-features" class="rpg-tab-content space-y-6">

          <!-- Features & Traits -->
          <div class="rpg-panel">
            <div class="rpg-panel-header">
              <span class="rpg-header-font font-bold text-sm">Features & Traits</span>
              <div class="feature-add text-blue-400 cursor-pointer text-xs hover:underline" onclick="addFeature()">+ Add
                Feature</div>
            </div>
            <div class="rpg-panel-content">
              <div id="features-list" class="space-y-3 max-h-[350px] overflow-y-auto">
                <% features.forEach(function(f, idx) { %>
                  <div class="feature-item" data-index="<%= idx %>">
                    <div class="flex items-start justify-between gap-2 mb-1">
                      <input type="text" name="features[<%= idx %>][name]" value="<%= f.name %>" readonly
                        class="font-bold bg-transparent border-none p-0 text-sm text-yellow-500 editable-input"
                        placeholder="Feature name" />
                      <span class="feature-delete" onclick="removeFeature('<%= idx %>')">&times;</span>
                    </div>
                    <textarea name="features[<%= idx %>][description]" readonly
                      class="w-full bg-transparent border-none p-0 text-xs text-gray-300 resize-none editable-input"
                      rows="2" placeholder="Description"><%= f.description %></textarea>
                  </div>
                  <% }); %>
              </div>
            </div>
          </div>

          <!-- Other Proficiencies -->
          <div class="rpg-panel">
            <div class="rpg-panel-header">
              <span class="rpg-header-font font-bold text-sm">Other Proficiencies & Languages</span>
            </div>
            <div class="rpg-panel-content">
              <textarea name="otherProficienciesText"
                class="w-full h-24 bg-transparent border-none p-0 text-sm text-gray-300 resize-none editable-input"
                readonly><%= otherProfs.join('\n') %></textarea>
            </div>
          </div>

          <!-- Personality Details -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="rpg-panel">
              <div class="rpg-panel-header"><span class="rpg-header-font font-bold text-xs">Personality Traits</span>
              </div>
              <div class="rpg-panel-content">
                <textarea name="traits[personalityTrait]"
                  class="w-full h-24 bg-transparent border-none p-0 text-sm text-gray-300 resize-none editable-input"
                  readonly
                  placeholder="Personality traits..."><%= character.traits?.personalityTrait || '' %></textarea>
              </div>
            </div>
            <div class="rpg-panel">
              <div class="rpg-panel-header"><span class="rpg-header-font font-bold text-xs">Ideals</span></div>
              <div class="rpg-panel-content">
                <textarea name="traits[ideal]"
                  class="w-full h-24 bg-transparent border-none p-0 text-sm text-gray-300 resize-none editable-input"
                  readonly placeholder="Ideals..."><%= character.traits?.ideal || '' %></textarea>
              </div>
            </div>
            <div class="rpg-panel">
              <div class="rpg-panel-header"><span class="rpg-header-font font-bold text-xs">Bonds</span></div>
              <div class="rpg-panel-content">
                <textarea name="traits[bond]"
                  class="w-full h-24 bg-transparent border-none p-0 text-sm text-gray-300 resize-none editable-input"
                  readonly placeholder="Bonds..."><%= character.traits?.bond || '' %></textarea>
              </div>
            </div>
            <div class="rpg-panel">
              <div class="rpg-panel-header"><span class="rpg-header-font font-bold text-xs">Flaws</span></div>
              <div class="rpg-panel-content">
                <textarea name="traits[flaw]"
                  class="w-full h-24 bg-transparent border-none p-0 text-sm text-gray-300 resize-none editable-input"
                  readonly placeholder="Flaws..."><%= character.traits?.flaw || '' %></textarea>
              </div>
            </div>
          </div>

        </section>

        <!-- TAB 4: Spellbook -->
        <% if (spellData) { %>
          <section id="tab-spellbook" class="rpg-tab-content space-y-6">

            <!-- Spellcasting Stats -->
            <div class="rpg-panel">
              <div class="rpg-panel-header">
                <span class="rpg-header-font font-bold text-sm">
                  <%= spellData.className %> Spellcasting
                </span>
              </div>
              <div class="rpg-panel-content">
                <div class="grid grid-cols-3 gap-4 text-center">
                  <div class="rpg-combat-stat-box">
                    <span class="label-small">Ability</span>
                    <span class="font-bold text-lg text-gray-200">
                      <%= spellData.ability %>
                    </span>
                  </div>
                  <div class="rpg-combat-stat-box">
                    <span class="label-small">Save DC</span>
                    <input name="spellSaveDC"
                      class="w-12 text-center bg-transparent border-none p-0 font-bold text-lg text-yellow-500 editable-input"
                      type="number" value="<%= spellData.saveDC %>" readonly min="0" />
                  </div>
                  <div class="rpg-combat-stat-box">
                    <span class="label-small">Attack Bonus</span>
                    <input name="spellAttackBonus"
                      class="w-12 text-center bg-transparent border-none p-0 font-bold text-lg text-yellow-500 editable-input"
                      type="number" value="<%= spellData.attackBonus %>" readonly />
                  </div>
                </div>
              </div>
            </div>

            <!-- Spells Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

              <!-- Cantrips -->
              <div class="rpg-spell-level-section">
                <div class="rpg-spell-level-header">
                  <span>Cantrips (Level 0)</span>
                </div>
                <div class="p-3 space-y-2 bg-slate-900/40">
                  <% spellData.cantrips.forEach(function(s) { %>
                    <div class="py-1 px-2 border-b border-gray-800 text-sm text-gray-200">
                      <span class="rpg-tooltip-trigger" data-type="spell" data-name="<%= s.name %>"
                        data-source="<%= s.source %>">
                        <%= s.name %>
                      </span>
                    </div>
                    <% }); %>
                      <% if (spellData.cantrips.length===0) { %>
                        <div class="text-gray-500 italic text-sm">None</div>
                        <% } %>
                </div>
              </div>

              <!-- Leveled Spells -->
              <% [1, 2, 3, 4, 5, 6, 7, 8, 9].forEach(function(lvl) { %>
                <% if (spellData.slots[lvl] || (spellData.spellsByLevel[lvl] && spellData.spellsByLevel[lvl].length> 0))
                  { %>
                  <div class="rpg-spell-level-section">
                    <div class="rpg-spell-level-header">
                      <span>Level <%= lvl %> Spells</span>
                      <div class="flex items-center gap-2 text-xs">
                        <span>Slots:</span>
                        <input name="spellSlots[<%= lvl %>][max]"
                          class="w-8 text-center bg-transparent border-none p-0 font-bold text-yellow-500 editable-input"
                          type="number" value="<%= spellData.slots[lvl] ? spellData.slots[lvl].max : 0 %>" readonly
                          min="0" />
                        <span>Used:</span>
                        <input name="spellSlots[<%= lvl %>][used]"
                          class="w-8 text-center bg-transparent border-none p-0 font-bold text-yellow-500 editable-input"
                          type="number" value="<%= spellData.slots[lvl] ? spellData.slots[lvl].used : 0 %>" readonly
                          min="0" />
                      </div>
                    </div>
                    <div class="p-3 space-y-2 bg-slate-900/40">
                      <% (spellData.spellsByLevel[lvl] || []).forEach(function(s) { %>
                        <div class="flex items-center gap-2 py-1 px-2 border-b border-gray-800 text-sm text-gray-200">
                          <div class="bubble spell-checkbox"></div>
                          <span class="rpg-tooltip-trigger" data-type="spell" data-name="<%= s.name %>"
                            data-source="<%= s.source %>">
                            <%= s.name %>
                          </span>
                        </div>
                        <% }); %>
                          <% if (!(spellData.spellsByLevel[lvl] || []).length) { %>
                            <div class="text-gray-500 italic text-sm">No spells known.</div>
                            <% } %>
                    </div>
                  </div>
                  <% } %>
                    <% }); %>

            </div>

          </section>
          <% } %>

      </main>

    </div>

  </form>

  <!-- Tooltip Container -->
  <div id="rpg-tooltip" class="rpg-tooltip hidden"></div>

  <!-- Global variables for character.js -->
  <script>
    window.characterId = "<%= character.id %>";
    window.characterName = "<%= character.name %>";
    window.initialEquipmentCount = parseInt("<%= (equipment || []).length %>") || 0;
    window.initialFeatureCount = parseInt("<%= (features || []).length %>") || 0;
  </script>
  <script src="/js/character.js"></script>

</body>

</html>