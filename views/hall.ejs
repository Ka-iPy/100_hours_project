<% include('partials/header.ejs') %>
<main>
  <h1>
      Greetings, <%= username %>!
  </h1>
  <a href="/logout">Logout</a>
  <a href="/createCharacter">Create a Character</a>

  <h2>Your Characters</h2>
  <% if (characters && characters.length > 0) { %>
    <ul>
      <% characters.forEach(function(char) { %>
        <li>
          <a href="/character/<%= char.id %>">
            <%= char.name %> — Level <%= char.getTotalLevel() %> <%= char.classes.length > 0 ? char.classes[0].className : '' %>
          </a>
          <button type="button" id="delete-btn" onclick='confirmDelete(<%- JSON.stringify({
            id: char.id,
            name: char.name
          }) %>)'
            class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">
            Delete Character
          </button>
        </li>
      <% }); %>
    </ul>
  <% } else { %>
    <p>You haven't created any characters yet.</p>
  <% } %>
</main>
<script>
  async function confirmDelete(char) {
    const charName = char.name;

    if (confirm(`Are you sure you want to delete ${charName}? This action cannot be undone.`)) {
      try {
        const response = await fetch(`/character/${char.id}`, {
          method: 'DELETE',
        });

        if (response.redirected) {
          window.location.href = response.url;
        } else if (response.ok) {
          window.location.href = '/hall';
        } else {
          const error = await response.json();
          alert('Error deleting: ' + (error.error || 'Unknown error'));
        }
      } catch (err) {
        alert('Error deleting: ' + err.message);
      }
    }
  }
</script>
<% include('partials/footer.ejs') %>
