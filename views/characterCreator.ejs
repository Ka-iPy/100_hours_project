<%- include('partials/header.ejs') %>

  <main class="creator-page">
    <h1>Create a Character</h1>

    <form id="characterForm" action="/createCharacter" method="POST" class="creator-form">

      <!-- Basic Info -->
      <div class="creator-section">
        <div class="creator-section-header">
          <h2>Basic Info</h2>
        </div>
        <div class="creator-section-body">
          <div class="creator-field">
            <label for="name">Character Name</label>
            <input type="text" id="name" name="name" required>
          </div>
        </div>
      </div>

      <!-- Race & Heritage -->
      <div class="creator-section">
        <div class="creator-section-header">
          <h2>Race & Heritage</h2>
        </div>
        <div class="creator-section-body">
          <div class="creator-row cols-2">
            <div class="creator-field">
              <label for="race">Race</label>
              <select id="race" name="race" required>
                <option value="">Select a race...</option>
                <% races.forEach(race=> {
                  const r = JSON.parse(race); %>
                  <option value="<%= race %>">
                    <%= `${r.name} (${r.source})` %>
                  </option>
                  <% }) %>
              </select>
            </div>

            <div class="creator-field" id="subraceContainer" style="display: none;">
              <label for="subrace">Subrace</label>
              <select id="subrace" name="subrace">
                <option value="">None</option>
                <% subraces.forEach(sub=> {
                  const sr = JSON.parse(sub); %>
                  <option value="<%= sub %>" data-parent="<%= sr.raceName %>" data-race-source="<%= sr.raceSource %>">
                    <%= `${sr.name} (${sr.source})` %>
                  </option>
                  <% }) %>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Class & Level -->
      <div class="creator-section">
        <div class="creator-section-header">
          <h2>Class & Level</h2>
        </div>
        <div class="creator-section-body">
          <div class="creator-row cols-3">
            <div class="creator-field">
              <label for="className">Class</label>
              <select id="className" name="className" required>
                <option value="">Select a class...</option>
                <% classes.forEach(cls=> {
                  const c = JSON.parse(cls); %>
                  <option value="<%= cls %>">
                    <%= `${c.name} (${c.source})` %>
                  </option>
                  <% }) %>
              </select>
            </div>

            <div class="creator-field">
              <label for="level">Level</label>
              <input type="number" id="level" name="level" min="1" max="20" value="1" required>
            </div>

            <div id="subclassContainer" class="creator-field" style="display: none;">
              <label for="subclass">Subclass</label>
              <select id="subclass" name="subclass">
                <option value="">None</option>
                <% subclasses.forEach(sc=> {
                  const s = JSON.parse(sc); %>
                  <option value="<%= sc %>" data-class="<%= s.className %>">
                    <%= `${s.name} (${s.source})` %>
                  </option>
                  <% }) %>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Ability Scores -->
      <div class="creator-section">
        <div class="creator-section-header">
          <h2>Ability Scores</h2>
        </div>
        <div class="creator-section-body">
          <div class="creator-row cols-6">
            <% abilities.forEach(ability=> {
              const displayName = ability.charAt(0).toUpperCase() + ability.slice(1); %>
              <div class="creator-ability-card">
                <label for="stat_<%= ability %>">
                  <%= displayName %>
                </label>
                <input type="number" id="stat_<%= ability %>" name="stats[<%= ability %>]" min="1" max="20" value="10">
              </div>
              <% }) %>
          </div>
        </div>
      </div>

      <!-- Background & Alignment -->
      <div class="creator-section">
        <div class="creator-section-header">
          <h2>Background & Alignment</h2>
        </div>
        <div class="creator-section-body">
          <div class="creator-row cols-2">
            <div class="creator-field">
              <label for="background">Background</label>
              <select id="background" name="background" required>
                <option value="">Select a background...</option>
                <% backgrounds.forEach(bg=> {
                  const b = JSON.parse(bg); %>
                  <option value="<%= bg %>">
                    <%= `${b.name} (${b.source})` %>
                  </option>
                  <% }) %>
              </select>
            </div>
            <div class="creator-field">
              <label for="alignment">Alignment</label>
              <select id="alignment" name="alignment">
                <% alignments.forEach(align=> { %>
                  <option value="<%= align %>">
                    <%= align %>
                  </option>
                  <% }) %>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Feats -->
      <div class="creator-section" id="featsSection" style="display: none;">
        <div class="creator-section-header">
          <h2>Feats <span id="featsCounter" class="creator-counter"></span></h2>
        </div>
        <div class="creator-section-body">
          <div id="featSlotsContainer" class="creator-eq-choices">
            <!-- Dynamic feat slots will be rendered here -->
          </div>
        </div>
      </div>

      <!-- Starting Equipment (dynamically loaded) -->
      <div id="equipmentSection" class="creator-section" style="display: none;">
        <div class="creator-section-header">
          <h2>Starting Equipment</h2>
        </div>
        <div class="creator-section-body">
          <div id="equipmentChoices"></div>
          <div id="equipmentGoldAlt" class="creator-gold-alt"></div>
        </div>
      </div>

      <!-- Spell Selection (dynamically loaded) -->
      <div id="spellSection" class="creator-section" style="display: none;">
        <div class="creator-section-header">
          <h2>Spellcasting</h2>
        </div>
        <div class="creator-section-body">
          <div id="spellInfo"></div>

          <!-- Cantrips -->
          <div id="cantripSection" style="display: none;">
            <h3 class="hall-section-title" style="margin-top: 12px;">Cantrips <span id="cantripCounter"
                class="creator-counter"></span></h3>
            <div id="cantripList" class="creator-pick-grid"></div>
          </div>

          <!-- Spells -->
          <div id="spellPickSection" style="display: none; margin-top: 16px;">
            <h3 class="hall-section-title">Spells <span id="spellCounter" class="creator-counter"></span></h3>
            <div id="spellLevelFilter" class="creator-filter-bar"></div>
            <div id="spellList" class="creator-pick-grid"></div>
          </div>
        </div>
      </div>

      <button type="submit" class="creator-submit">Create Character</button>
    </form>

    <div id="characterPreview" class="creator-preview">
      <h2>Character Preview</h2>
      <pre id="characterJson"></pre>
    </div>
  </main>

  <script>
    const allFeats = [
      <% feats.forEach(feat => { %>
        <%- feat %>,
      <% }) %>
    ];
    const form = document.getElementById('characterForm');
    const preview = document.getElementById('characterPreview');
    const jsonDisplay = document.getElementById('characterJson');

    const raceSelect = document.getElementById('race');
    const subraceSelect = document.getElementById('subrace');
    const subraceContainer = document.getElementById('subraceContainer');

    const classSelect = document.getElementById('className');
    const subclassSelect = document.getElementById('subclass');
    const subclassContainer = document.getElementById('subclassContainer');
    const levelInput = document.getElementById('level');

    // State for spell/equipment selections
    let selectedCantrips = [];
    let selectedSpells = [];
    let spellContext = null;

    function safeParse(val) {
      if (!val) return null;
      try { return JSON.parse(val); } catch (e) { return null; }
    }

    // --- Feat Slot Logic ---
    let selectedRaceData = null;
    let selectedBgData = null;

    function findFeat(key) {
      const [namePart, sourcePart] = key.split('|');
      const cleanName = namePart.trim().toLowerCase();
      const cleanSource = sourcePart ? sourcePart.trim().toLowerCase() : null;
      return allFeats.find(f => {
        const nameMatch = f.name.toLowerCase() === cleanName;
        const sourceMatch = !cleanSource || f.source.toLowerCase() === cleanSource;
        return nameMatch && sourceMatch;
      });
    }

    function getSubVersions(featName) {
      const prefix = featName.toLowerCase() + ';';
      return allFeats.filter(f => f.name.toLowerCase().startsWith(prefix));
    }

    function populateFeatSelect(selectEl, filterType, allowedKeys = null) {
      selectEl.innerHTML = '<option value="">Select a feat...</option>';

      let filtered = allFeats;

      if (allowedKeys) {
        filtered = allFeats.filter(f => {
          return allowedKeys.some(key => {
            const [namePart, sourcePart] = key.split('|');
            const cleanName = namePart.trim().toLowerCase();
            const cleanSource = sourcePart ? sourcePart.trim().toLowerCase() : null;
            return f.name.toLowerCase() === cleanName && (!cleanSource || f.source.toLowerCase() === cleanSource);
          });
        });
      } else if (filterType === 'O') {
        filtered = allFeats.filter(f => f.category === 'O');
      }

      // Sort alphabetically
      filtered.sort((a, b) => a.name.localeCompare(b.name));

      filtered.forEach(f => {
        const option = document.createElement('option');
        option.value = JSON.stringify(f);
        option.textContent = `${f.name} (${f.source})`;
        selectEl.appendChild(option);
      });
    }

    function handleFeatSelectionChange() {
      const selects = Array.from(document.querySelectorAll('.feat-slot-select'));
      const selectedValues = selects.map(s => s.value).filter(val => val !== "");

      selects.forEach(currentSelect => {
        const currentValue = currentSelect.value;
        Array.from(currentSelect.options).forEach(option => {
          if (option.value === "") return;
          const isSelectedElsewhere = selectedValues.includes(option.value) && option.value !== currentValue;
          option.disabled = isSelectedElsewhere;
        });
      });
    }

    function renderFeatSlots(classVal, level) {
      const container = document.getElementById('featSlotsContainer');
      const section = document.getElementById('featsSection');
      const counter = document.getElementById('featsCounter');

      container.innerHTML = '';

      const slots = [];

      // 1. Background Feats
      if (selectedBgData && selectedBgData.feats) {
        if (selectedBgData.feats.length > 1) {
          const keys = selectedBgData.feats.map(f => Object.keys(f)[0]);
          slots.push({
            label: `Background Feat Choice (${selectedBgData.name})`,
            type: 'choice',
            allowedKeys: keys
          });
        } else if (selectedBgData.feats.length === 1) {
          const key = Object.keys(selectedBgData.feats[0])[0];
          const feat = findFeat(key);
          if (feat) {
            const subVersions = getSubVersions(feat.name);
            if (subVersions.length > 0) {
              slots.push({
                label: `Background Feat Choice (${selectedBgData.name} - ${feat.name})`,
                type: 'choice',
                allowedKeys: subVersions.map(sv => `${sv.name}|${sv.source}`)
              });
            } else {
              slots.push({
                label: `Background Feat (${selectedBgData.name})`,
                type: 'fixed',
                feat: feat
              });
            }
          }
        }
      }

      // 2. Race Feats
      if (selectedRaceData && selectedRaceData.feats) {
        selectedRaceData.feats.forEach(f => {
          if (f.any) {
            slots.push({
              label: `Race Feat Choice (${selectedRaceData.name})`,
              type: 'choice',
              filter: 'any'
            });
          } else if (f.anyFromCategory) {
            slots.push({
              label: `Race Feat Choice (${selectedRaceData.name})`,
              type: 'choice',
              filter: f.anyFromCategory.category[0]
            });
          } else {
            const key = Object.keys(f)[0];
            const feat = findFeat(key);
            if (feat) {
              const subVersions = getSubVersions(feat.name);
              if (subVersions.length > 0) {
                slots.push({
                  label: `Race Feat Choice (${selectedRaceData.name} - ${feat.name})`,
                  type: 'choice',
                  allowedKeys: subVersions.map(sv => `${sv.name}|${sv.source}`)
                });
              } else {
                slots.push({
                  label: `Race Feat (${selectedRaceData.name})`,
                  type: 'fixed',
                  feat: feat
                });
              }
            }
          }
        });
      }

      // 3. Subrace Feats (Variant Human)
      const subraceVal = safeParse(subraceSelect.value);
      if (subraceVal && subraceVal.name.toLowerCase() === 'variant') {
        slots.push({
          label: `Variant Human Feat`,
          type: 'choice',
          filter: 'any'
        });
      }

      // 4. Class Feats (ASIs)
      if (classVal) {
        const classNameLower = classVal.name.toLowerCase();
        let asiLevels = [4, 8, 12, 16, 19];
        if (classNameLower === 'fighter') {
          asiLevels = [4, 6, 8, 12, 14, 16, 19];
        } else if (classNameLower === 'rogue') {
          asiLevels = [4, 8, 10, 12, 16, 19];
        }

        asiLevels.forEach(lvl => {
          if (level >= lvl) {
            slots.push({
              label: `Class Level ${lvl} Feat / ASI`,
              type: 'choice',
              filter: 'any'
            });
          }
        });
      }

      if (slots.length === 0) {
        section.style.display = 'none';
        return;
      }

      section.style.display = 'block';
      counter.textContent = `(${slots.length} Available)`;

      slots.forEach(slot => {
        const div = document.createElement('div');
        div.className = 'creator-field';
        div.style.marginBottom = '12px';

        const label = document.createElement('label');
        label.className = 'creator-eq-label';
        label.textContent = slot.label;
        div.appendChild(label);

        if (slot.type === 'fixed') {
          const inputGroup = document.createElement('div');
          inputGroup.style.display = 'flex';
          inputGroup.style.alignItems = 'center';
          inputGroup.style.gap = '8px';

          const textSpan = document.createElement('span');
          textSpan.className = 'rpg-panel';
          textSpan.style.padding = '6px 12px';
          textSpan.style.display = 'inline-block';
          textSpan.style.border = '1px solid var(--rpg-border)';
          textSpan.style.borderRadius = '4px';
          textSpan.style.backgroundColor = 'rgba(255, 255, 255, 0.03)';
          textSpan.textContent = `${slot.feat.name} (${slot.feat.source})`;

          const hiddenInput = document.createElement('input');
          hiddenInput.type = 'hidden';
          hiddenInput.name = 'feats';
          hiddenInput.value = JSON.stringify(slot.feat);

          inputGroup.appendChild(textSpan);
          inputGroup.appendChild(hiddenInput);
          div.appendChild(inputGroup);
        } else {
          const select = document.createElement('select');
          select.name = 'feats';
          select.className = 'feat-slot-select';
          populateFeatSelect(select, slot.filter, slot.allowedKeys);
          select.addEventListener('change', handleFeatSelectionChange);
          div.appendChild(select);
        }

        container.appendChild(div);
      });

      handleFeatSelectionChange();
    }

    async function updateFeatSlots() {
      const raceVal = safeParse(raceSelect.value);
      const bgVal = safeParse(document.getElementById('background').value);
      const classVal = safeParse(classSelect.value);
      const level = parseInt(levelInput.value) || 1;

      if (raceVal) {
        if (!selectedRaceData || selectedRaceData.name !== raceVal.name || selectedRaceData.source !== raceVal.source) {
          try {
            const res = await fetch(`/api/lookup?type=race&name=${encodeURIComponent(raceVal.name)}&source=${encodeURIComponent(raceVal.source)}`);
            selectedRaceData = await res.json();
          } catch (e) {
            console.error(e);
            selectedRaceData = null;
          }
        }
      } else {
        selectedRaceData = null;
      }

      if (bgVal) {
        if (!selectedBgData || selectedBgData.name !== bgVal.name || selectedBgData.source !== bgVal.source) {
          try {
            const res = await fetch(`/api/lookup?type=background&name=${encodeURIComponent(bgVal.name)}&source=${encodeURIComponent(bgVal.source)}`);
            selectedBgData = await res.json();
          } catch (e) {
            console.error(e);
            selectedBgData = null;
          }
        }
      } else {
        selectedBgData = null;
      }

      renderFeatSlots(classVal, level);
    }

    // --- Race / Subrace filtering ---
    raceSelect.addEventListener('change', () => {
      const data = safeParse(raceSelect.value);
      if (!data) { subraceContainer.style.display = 'none'; return; }
      const { name, source } = data;
      let count = 0;
      Array.from(subraceSelect.options).forEach(opt => {
        if (!opt.value) return;
        const isMatch = opt.dataset.parent === name && opt.dataset.raceSource === source;
        opt.style.display = isMatch ? 'block' : 'none';
        if (isMatch) count++;
      });
      subraceContainer.style.display = count > 0 ? 'block' : 'none';
      subraceSelect.value = "";
      updateFeatSlots();
    });

    subraceSelect.addEventListener('change', updateFeatSlots);
    document.getElementById('background').addEventListener('change', updateFeatSlots);

    // --- Subclass filtering ---
    function updateSubclassUI() {
      const data = safeParse(classSelect.value);
      const level = parseInt(levelInput.value) || 1;
      if (!data) { subclassContainer.style.display = 'none'; return; }
      const { name } = data;
      const nameLower = name.toLowerCase();
      const shouldShow = nameLower === 'warlock' || nameLower === 'cleric' || nameLower === 'sorcerer' || level >= 3;
      let count = 0;
      Array.from(subclassSelect.options).forEach(opt => {
        if (!opt.value) return;
        const isMatch = opt.dataset.class === name;
        opt.style.display = isMatch ? 'block' : 'none';
        if (isMatch) count++;
      });
      subclassContainer.style.display = (shouldShow && count > 0) ? 'block' : 'none';
    }
    classSelect.addEventListener('change', () => { updateSubclassUI(); loadEquipment(); loadSpellContext(); updateFeatSlots(); });
    levelInput.addEventListener('input', () => { updateSubclassUI(); loadSpellContext(); updateFeatSlots(); });
    subclassSelect.addEventListener('change', loadSpellContext);
    document.querySelectorAll('input[name^="stats["]').forEach(input => {
      input.addEventListener('input', updateSpellCounter);
    });

    // --- Equipment Loading ---
    async function loadEquipment() {
      const data = safeParse(classSelect.value);
      const section = document.getElementById('equipmentSection');
      const container = document.getElementById('equipmentChoices');
      const goldAlt = document.getElementById('equipmentGoldAlt');

      if (!data) { section.style.display = 'none'; return; }

      try {
        const res = await fetch(`/api/equipment/class/${encodeURIComponent(data.name)}?classSource=${encodeURIComponent(data.source)}`);
        const eq = await res.json();

        if (!eq.choices || eq.choices.length === 0) { section.style.display = 'none'; return; }

        container.innerHTML = '';
        eq.choices.forEach((choice, idx) => {
          const div = document.createElement('div');
          div.className = 'creator-eq-group';

          if (choice.isAutomatic) {
            const items = choice.options[0].items.map(i => i.data?.name || i.name).join(', ');
            div.innerHTML = `<div class="creator-eq-label">Included</div>
          <div style="font-size: 0.85rem;">${items}</div>
          <input type="hidden" name="equipmentChoices_group" value="${idx}" data-key="_">`;
          } else {
            let html = `<div class="creator-eq-label">Choose one</div>`;
            choice.options.forEach(opt => {
              const items = opt.items.map(i => i.data?.name || i.name).join(', ');
              html += `<label class="creator-eq-option">
              <input type="radio" name="eq_choice_${idx}" value="${opt.key}" data-group="${idx}" class="eq-radio">
              <span>(${opt.key}) ${items}</span>
            </label>`;
            });
            div.innerHTML = html;
          }
          container.appendChild(div);
        });

        if (eq.goldAlternative) {
          goldAlt.textContent = 'Or start with gold: ' + eq.goldAlternative.replace(/\{@dice ([^}]+)\}/g, '$1');
        } else {
          goldAlt.textContent = '';
        }

        section.style.display = 'block';
      } catch (e) {
        console.error('Equipment load error:', e);
        section.style.display = 'none';
      }
    }

    // --- Spell Context Loading ---
    async function loadSpellContext() {
      const data = safeParse(classSelect.value);
      const level = parseInt(levelInput.value) || 1;
      const spellSection = document.getElementById('spellSection');
      const spellInfo = document.getElementById('spellInfo');
      const cantripSection = document.getElementById('cantripSection');
      const spellPickSection = document.getElementById('spellPickSection');

      selectedCantrips = [];
      selectedSpells = [];

      if (!data) { spellSection.style.display = 'none'; return; }

      const scData = safeParse(subclassSelect.value);
      let url = `/api/spells/context/${encodeURIComponent(data.name)}/${level}?classSource=${encodeURIComponent(data.source)}`;
      if (scData) {
        url += `&subclassName=${encodeURIComponent(scData.name)}&subclassSource=${encodeURIComponent(scData.source)}`;
      }

      try {
        const res = await fetch(url);
        spellContext = await res.json();

        if (!spellContext.isCaster) {
          spellSection.style.display = 'none';
          return;
        }

        spellSection.style.display = 'block';
        const typeLabel = spellContext.acquisitionType === 'prepared' ? 'Prepared' : 'Known';
        const formulaNote = spellContext.preparedFormula ? ` (${spellContext.preparedFormula})` : '';
        spellInfo.innerHTML = `
      <div class="creator-spell-info">
        <div><strong>Caster Type:</strong> ${spellContext.casterProgression}</div>
        <div><strong>Spell Type:</strong> ${typeLabel}</div>
        <div><strong>Max Level:</strong> ${spellContext.maxSpellLevel}</div>
        <div><strong>Slots:</strong> ${spellContext.spellSlots.filter(s => s > 0).join(' / ')}</div>
      </div>`;

        // Cantrips
        if (spellContext.numCantrips > 0 && spellContext.cantrips.length > 0) {
          cantripSection.style.display = 'block';
          updateCantripCounter();
          const cantripList = document.getElementById('cantripList');
          cantripList.innerHTML = '';
          spellContext.cantrips.forEach(c => {
            const id = `cantrip_${c.name.replace(/\s+/g, '_')}`;
            const label = document.createElement('label');
            label.className = 'creator-pick-item';
            label.innerHTML = `<input type="checkbox" id="${id}" class="cantrip-cb" data-name="${c.name}" data-source="${c.source}">
          <span>${c.name}</span>`;
            cantripList.appendChild(label);
          });
          cantripList.addEventListener('change', handleCantripChange);
        } else {
          cantripSection.style.display = 'none';
        }

        // Spells
        if (spellContext.spells.length > 0) {
          spellPickSection.style.display = 'block';
          updateSpellCounter();

          // Level filter buttons
          const filterDiv = document.getElementById('spellLevelFilter');
          filterDiv.innerHTML = '';
          const levels = [...new Set(spellContext.spells.map(s => s.level))].sort();
          const allBtn = document.createElement('button');
          allBtn.type = 'button';
          allBtn.className = 'creator-filter-btn active';
          allBtn.textContent = 'All';
          allBtn.onclick = () => filterSpells(0, allBtn);
          filterDiv.appendChild(allBtn);
          levels.forEach(lvl => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'creator-filter-btn';
            btn.textContent = 'Level ' + lvl;
            btn.onclick = () => filterSpells(lvl, btn);
            filterDiv.appendChild(btn);
          });

          renderSpellList(0);
        } else {
          spellPickSection.style.display = 'none';
        }
      } catch (e) {
        console.error('Spell context load error:', e);
        spellSection.style.display = 'none';
      }
    }

    function handleCantripChange(e) {
      if (!e.target.classList.contains('cantrip-cb')) return;
      const name = e.target.dataset.name;
      const source = e.target.dataset.source;

      if (e.target.checked) {
        if (selectedCantrips.length >= spellContext.numCantrips) {
          e.target.checked = false;
          return;
        }
        selectedCantrips.push({ name, source });
      } else {
        selectedCantrips = selectedCantrips.filter(c => c.name !== name);
      }
      updateCantripCounter();
    }

    function updateCantripCounter() {
      const el = document.getElementById('cantripCounter');
      if (spellContext) {
        el.textContent = `(${selectedCantrips.length} / ${spellContext.numCantrips})`;
      }
    }

    function filterSpells(level, activeBtn) {
      document.querySelectorAll('#spellLevelFilter button').forEach(b => {
        b.className = 'creator-filter-btn';
      });
      activeBtn.className = 'creator-filter-btn active';
      renderSpellList(level);
    }

    function renderSpellList(filterLevel) {
      const spellList = document.getElementById('spellList');
      spellList.innerHTML = '';
      const spells = filterLevel === 0 ? spellContext.spells : spellContext.spells.filter(s => s.level === filterLevel);

      spells.forEach(s => {
        const id = `spell_${s.name.replace(/\s+/g, '_')}`;
        const checked = selectedSpells.some(sp => sp.name === s.name) ? 'checked' : '';
        const label = document.createElement('label');
        label.className = 'creator-pick-item';
        const concStr = s.concentration ? ' <span class="spell-badge conc">C</span>' : '';
        const ritStr = s.ritual ? ' <span class="spell-badge ritual">R</span>' : '';
        label.innerHTML = `<input type="checkbox" id="${id}" class="spell-cb" data-name="${s.name}" data-source="${s.source}" ${checked}>
      <span>L${s.level} ${s.name}${concStr}${ritStr}</span>`;
        spellList.appendChild(label);
      });

      spellList.removeEventListener('change', handleSpellChange);
      spellList.addEventListener('change', handleSpellChange);
    }

    function handleSpellChange(e) {
      if (!e.target.classList.contains('spell-cb')) return;
      const name = e.target.dataset.name;
      const source = e.target.dataset.source;

      if (e.target.checked) {
        if (spellContext.acquisitionType === 'known' && selectedSpells.length >= spellContext.numSpells) {
          e.target.checked = false;
          return;
        }
        selectedSpells.push({ name, source });
      } else {
        selectedSpells = selectedSpells.filter(s => s.name !== name);
      }
      updateSpellCounter();
    }

    function updateSpellCounter() {
      const el = document.getElementById('spellCounter');
      if (!spellContext) return;
      if (spellContext.acquisitionType === 'known') {
        el.textContent = `(${selectedSpells.length} / ${spellContext.numSpells} known)`;
      } else {
        const level = parseInt(levelInput.value) || 1;
        const ability = spellContext.spellcastingAbility || 'intelligence';
        const scoreInput = document.getElementById('stat_' + ability.toLowerCase());
        const score = scoreInput ? (parseInt(scoreInput.value) || 10) : 10;
        const abilityMod = Math.floor((score - 10) / 2);

        let maxPrepared = spellContext.numSpells;
        if (spellContext.preparedFormula) {
          const result = spellContext.preparedFormula
            .replace(/<\$level\$>/g, String(level))
            .replace(/<\$(?:int|wis|cha|str|dex|con)_mod\$>/g, String(abilityMod));
          try {
            const num = Function(`"use strict"; return (${result})`)();
            maxPrepared = Math.max(1, Math.floor(num));
          } catch (e) {
            maxPrepared = Math.max(1, level + abilityMod);
          }
        }
        el.textContent = `(${selectedSpells.length} selected — prepare ${maxPrepared} per day)`;
      }
    }

    // --- Form Submission ---
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);

      try {
        const raceData = safeParse(formData.get('race'));
        const classData = safeParse(formData.get('className'));
        const bgData = safeParse(formData.get('background'));

        if (!raceData || !classData || !bgData) throw new Error("Missing required data");

        // Gather equipment choices
        const equipChoices = [];
        document.querySelectorAll('.eq-radio:checked').forEach(radio => {
          equipChoices.push({ groupIndex: parseInt(radio.dataset.group), choiceKey: radio.value });
        });
        // Include automatic items
        document.querySelectorAll('input[name="equipmentChoices_group"]').forEach(hidden => {
          equipChoices.push({ groupIndex: parseInt(hidden.value), choiceKey: hidden.dataset.key });
        });

        const payload = {
          name: formData.get('name'),
          race: raceData.name,
          raceSource: raceData.source,
          className: classData.name,
          classSource: classData.source,
          level: parseInt(formData.get('level')),
          background: bgData.name,
          backgroundSource: bgData.source,
          alignment: formData.get('alignment'),
          stats: {
            strength: parseInt(formData.get('stats[strength]')),
            dexterity: parseInt(formData.get('stats[dexterity]')),
            constitution: parseInt(formData.get('stats[constitution]')),
            intelligence: parseInt(formData.get('stats[intelligence]')),
            wisdom: parseInt(formData.get('stats[wisdom]')),
            charisma: parseInt(formData.get('stats[charisma]'))
          },
          feats: Array.from(formData.getAll('feats')).map(f => safeParse(f)).filter(f => f),
          selectedCantrips,
          selectedSpells,
          equipmentChoices: equipChoices,
        };

        const srVal = formData.get('subrace');
        const srData = safeParse(srVal);
        if (srData) {
          payload.subrace = srData.name;
          payload.subraceSource = srData.source;
        }

        const scVal = formData.get('subclass');
        const scData = safeParse(scVal);
        if (scData) {
          payload.subclass = scData.name;
          payload.subclassSource = scData.source;
        }

        const response = await fetch('/createCharacter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const result = await response.json();
        if (response.ok) {
          preview.classList.add('visible');
          jsonDisplay.textContent = JSON.stringify(result, null, 2);
          if (result.id) setTimeout(() => window.location.href = `/character/${result.id}`, 1500);
        } else {
          alert('Error: ' + result.error);
        }
      } catch (err) {
        console.error(err);
        alert('Submission failed. Check your choices.');
      }
    });

    // Initialize feat slots on page load
    updateFeatSlots();
  </script>

